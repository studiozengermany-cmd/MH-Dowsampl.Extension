{
  "manifest_version": 3,
  "name": "MH-Downsample Pro",
  "version": "1.0.0",
  "description": "Trình thu thập và tải file âm thanh gốc từ web về máy local.",
  "permissions": ["storage"],
  "host_permissions": ["http://127.0.0.1:8765/*"],
  "action": {
    "default_title": "MH-Downsample Pro",
    "default_popup": "popup.html"
  }
}
